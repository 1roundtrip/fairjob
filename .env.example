# ==================== 数据库 ====================
# 开发环境：本地 SQLite
DATABASE_URL="file:./dev.db"

# 生产环境：Turso 分布式 SQLite（推荐，免费）
# 获取地址：https://turso.tech
# DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-auth-token"

# ==================== 数据源 API ====================
# Bing 搜索 API（可选，用于发现新职位）
BING_SEARCH_API_KEY=""
BING_SEARCH_ENDPOINT="https://api.bing.microsoft.com/v7.0/search"

# OpenAI API（可选，用于 LLM 增强解析低置信度岗位）
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-3.5-turbo"

# ==================== 抓取配置 ====================
# 每个域名请求间隔（秒），遵守 robots.txt
CRAWL_DELAY_SECONDS=10

# 最大并发请求数
MAX_CONCURRENT_REQUESTS=3

# 单次抓取最大职位数（防止单个源过多）
MAX_JOBS_PER_SOURCE=200

# ==================== 监控与通知 ====================
# Webhook 通知（任选其一或多个，用于抓取失败告警）
BARK_WEBHOOK_URL=""
SERVERCHAN_SENDKEY=""
DINGTALK_WEBHOOK_URL=""

# 连续失败 N 次后触发告警
ALERT_FAILURE_THRESHOLD=3

# ==================== 定时任务认证 ====================
# Vercel/GitHub Actions Cron 认证密钥（防止他人恶意触发）
CRON_SECRET="generate-a-random-secret-string"

# ==================== 站点配置 ====================
NEXT_PUBLIC_SITE_NAME="FairJob 公平求职"
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# ==================== 管理后台认证 ====================
# 管理员账号密码（必须修改！）
# 生成密码哈希: node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('your-password', 10))"
ADMIN_USERNAME="your-admin-username"
ADMIN_PASSWORD_HASH="generate-with-bcrypt-above"

# JWT 密钥（必须修改！生成方法: openssl rand -base64 32）
JWT_SECRET="generate-a-random-64-char-string"
